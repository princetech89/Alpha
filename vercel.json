{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*",        "destination": "/api/index" },
    { "source": "/upstox-callback",   "destination": "/api/index" },
    { "source": "/(.*)",              "destination": "/index.html" }
  ]
}

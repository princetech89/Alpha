{
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "functions": {
    "api/bundle.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*",      "destination": "/api/bundle" },
    { "source": "/upstox-callback", "destination": "/api/bundle" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
